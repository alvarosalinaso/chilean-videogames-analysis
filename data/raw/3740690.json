i.steamstatic.com/store_item_assets/steam/apps/3740690/extras/f3cc9cf5552b09c03b6f3c3f6ea26933.poster.avif?t=1756773590\" width=678 height=384 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3740690/extras/f3cc9cf5552b09c03b6f3c3f6ea26933.webm?t=1756773590\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3740690/extras/f3cc9cf5552b09c03b6f3c3f6ea26933.mp4?t=1756773590\" type=\"video/mp4\"></video></span></p></li><li><p class=\"bb_paragraph\" ><strong>Un mundo lleno de interacciones atractivas y dinámicas:</strong> El mundo de <i>Hybrid Blood</i> está lleno de objetos dinámicos: la mayoría pueden ser destruidos o interactuar con ellos de diferentes formas. Incluso pueden interactuar entre sí, generando posibilidades de juego emergentes.</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3740690/extras/d6980c016749421887a605317f686e08.poster.avif?t=1756773590\" width=798 height=358 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3740690/extras/d6980c016749421887a605317f686e08.webm?t=1756773590\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3740690/extras/d6980c016749421887a605317f686e08.mp4?t=1756773590\" type=\"video/mp4\"></video></span></p></li></ul>",
    "short_description": "Entra en el rol de un Híbrido Vampiro-Humano, prisionero hace más tiempo del que puede recordar. Explora un RPG de mundo abierto pequeño y expande tu Dominio Vampírico. Derrota al Señor Vampiro local para reclamar su territorio y comienza tu misión: dominar o liberar estas tierras.",
